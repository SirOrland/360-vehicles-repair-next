generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement()) @map("user_id")
  name             String
  email            String    @unique
  password         String
  contact          String?
  role             String    @default("Customer")
  status           String    @default("Active")
  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  vehicles        Vehicle[]
  appointments    Appointment[] @relation("CustomerAppointments")
  mechanicJobs    Appointment[] @relation("MechanicAppointments")
  stockMovements  StockMovement[]
  purchaseOrders  PurchaseOrder[]
  serviceHistory  ServiceHistory[]
  notifications   Notification[]
  activityLogs    ActivityLog[]

  @@map("users")
}

model Vehicle {
  id        Int      @id @default(autoincrement()) @map("vehicle_id")
  userId    Int      @map("user_id")
  brand     String
  model     String
  year      Int?
  plateNo   String   @unique @map("plate_no")
  vin       String?
  color     String?
  createdAt DateTime @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments   Appointment[]
  serviceHistory ServiceHistory[]

  @@map("vehicles")
}

model Service {
  id                Int      @id @default(autoincrement()) @map("service_id")
  serviceName       String   @map("service_name")
  description       String?
  estimatedDuration Int?     @map("estimated_duration")
  basePrice         Decimal? @map("base_price")
  status            String   @default("Active")
  createdAt         DateTime @default(now()) @map("created_at")

  appointments Appointment[]

  @@map("services")
}

model Appointment {
  id              Int      @id @default(autoincrement()) @map("appointment_id")
  userId          Int      @map("user_id")
  vehicleId       Int      @map("vehicle_id")
  serviceId       Int      @map("service_id")
  appointmentDate DateTime @map("appointment_date")
  appointmentTime String   @map("appointment_time")
  status          String   @default("Pending")
  mechanicId      Int?     @map("mechanic_id")
  notes           String?
  customerNotes   String?  @map("customer_notes")
  estimatedCost   Decimal? @map("estimated_cost")
  finalCost       Decimal? @map("final_cost")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  customer       User             @relation("CustomerAppointments", fields: [userId], references: [id], onDelete: Cascade)
  vehicle        Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  service        Service          @relation(fields: [serviceId], references: [id])
  mechanic       User?            @relation("MechanicAppointments", fields: [mechanicId], references: [id], onDelete: SetNull)
  partsUsage     PartsUsage[]
  serviceHistory ServiceHistory[]

  @@map("appointments")
}

model InventoryPart {
  id              Int      @id @default(autoincrement()) @map("part_id")
  partName        String   @map("part_name")
  partNumber      String?  @unique @map("part_number")
  description     String?
  brand           String?
  category        String?
  unitPrice       Decimal  @map("unit_price")
  quantityInStock Int      @default(0) @map("quantity_in_stock")
  reorderLevel    Int      @default(10) @map("reorder_level")
  supplierId      Int?     @map("supplier_id")
  status          String   @default("Active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]
  partsUsage     PartsUsage[]
  poItems        PurchaseOrderItem[]

  @@map("inventory_parts")
}

model Supplier {
  id            Int      @id @default(autoincrement()) @map("supplier_id")
  supplierName  String   @map("supplier_name")
  contactPerson String?  @map("contact_person")
  email         String?
  phone         String?
  address       String?
  status        String   @default("Active")
  createdAt     DateTime @default(now()) @map("created_at")

  parts          InventoryPart[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model StockMovement {
  id            Int      @id @default(autoincrement()) @map("movement_id")
  partId        Int      @map("part_id")
  movementType  String   @map("movement_type")
  quantity      Int
  referenceType String?  @map("reference_type")
  referenceId   Int?     @map("reference_id")
  notes         String?
  createdBy     Int      @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  part    InventoryPart @relation(fields: [partId], references: [id], onDelete: Cascade)
  creator User          @relation(fields: [createdBy], references: [id])

  @@map("stock_movements")
}

model PartsUsage {
  id            Int      @id @default(autoincrement()) @map("usage_id")
  appointmentId Int      @map("appointment_id")
  partId        Int      @map("part_id")
  quantityUsed  Int      @map("quantity_used")
  unitPrice     Decimal  @map("unit_price")
  totalPrice    Decimal  @map("total_price")
  createdAt     DateTime @default(now()) @map("created_at")

  appointment Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  part        InventoryPart @relation(fields: [partId], references: [id])

  @@map("parts_usage")
}

model PurchaseOrder {
  id               Int      @id @default(autoincrement()) @map("po_id")
  supplierId       Int      @map("supplier_id")
  poNumber         String   @unique @map("po_number")
  orderDate        DateTime @map("order_date")
  expectedDelivery DateTime? @map("expected_delivery")
  status           String   @default("Pending")
  totalAmount      Decimal? @map("total_amount")
  notes            String?
  createdBy        Int      @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  creator  User                @relation(fields: [createdBy], references: [id])
  items    PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id         Int     @id @default(autoincrement()) @map("po_item_id")
  poId       Int     @map("po_id")
  partId     Int     @map("part_id")
  quantity   Int
  unitPrice  Decimal @map("unit_price")
  totalPrice Decimal @map("total_price")

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  part          InventoryPart @relation(fields: [partId], references: [id])

  @@map("purchase_order_items")
}

model ServiceHistory {
  id                 Int      @id @default(autoincrement()) @map("history_id")
  appointmentId      Int      @map("appointment_id")
  vehicleId          Int      @map("vehicle_id")
  serviceDate        DateTime @map("service_date")
  mechanicId         Int?     @map("mechanic_id")
  serviceDescription String?  @map("service_description")
  laborHours         Decimal? @map("labor_hours")
  laborCost          Decimal? @map("labor_cost")
  partsCost          Decimal? @map("parts_cost")
  totalCost          Decimal? @map("total_cost")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
  mechanic    User?       @relation(fields: [mechanicId], references: [id])

  @@map("service_history")
}

model Notification {
  id        Int      @id @default(autoincrement()) @map("notification_id")
  userId    Int      @map("user_id")
  title     String
  message   String
  type      String   @default("Info")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SystemSetting {
  id           Int      @id @default(autoincrement()) @map("setting_id")
  settingKey   String   @unique @map("setting_key")
  settingValue String?  @map("setting_value")
  description  String?
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model ActivityLog {
  id          Int      @id @default(autoincrement()) @map("log_id")
  userId      Int?     @map("user_id")
  action      String
  description String?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}
